import random
import time

# Fungsi A: Nested loop
def find_duplicates_nested_loop(lst):
    duplicates = []
    for i in range(len(lst)):
        for j in range(i + 1, len(lst)):
            if lst[i] == lst[j] and lst[i] not in duplicates:
                duplicates.append(lst[i])
    return duplicates

# Fungsi B: Menggunakan set
def find_duplicates_set(lst):
    seen = set()
    duplicates = set()
    for num in lst:
        if num in seen:
            duplicates.add(num)
        else:
            seen.add(num)
    return list(duplicates)

# Data ukuran berbeda
sizes = [100, 1000, 10000]

for n in sizes:
    # Membuat data acak dengan kemungkinan duplikat
    data = [random.randint(1, n // 2) for _ in range(n)]
    
    print(f"\nUji Penetrasi untuk n = {n} elemen:")
    
    start_time = time.time()
    result_nested = find_duplicates_nested_loop(data)
    elapsed_nested = time.time() - start_time
    print(f"Nested Loop: {len(result_nested)} duplikat ditemukan dalam {elapsed_nested:.4f} detik")
    
    start_time = time.time()
    result_set = find_duplicates_set(data)
    elapsed_set = time.time() - start_time
    print(f"Set Method: {len(result_set)} duplikat ditemukan dalam {elapsed_set:.4f} detik")
    
