class Node:
    def __init__(self, data):
        self.data = data
        self.next = None
        self.prev = None

class DoublyLinkedList:
    def __init__(self):
        self.head = None

    # 1. Menghitung panjang DLL
    def length(self):
        count = 0
        current = self.head
        while current:
            count += 1  # Perbaikan operator
            current = current.next
        return count  # Perbaikan indentasi

    # 2. Mencari node
    def search(self, key):
        current = self.head
        while current:
            if current.data == key:
                return True
            current = current.next
        return False

    # 3. Membalikkan DLL
    def reverse(self):
        current = self.head
        temp = None
        while current:
            # Tukar prev dan next
            temp = current.prev
            current.prev = current.next
            current.next = temp
            current = current.prev  # Karena pointer sudah ditukar

        if temp:
            self.head = temp.prev  # Update head ke node baru

    # 4. Menghapus seluruh node
    def clear(self):
        current = self.head
        while current:
            temp = current
            current = current.next
            temp.prev = None
            temp.next = None
        self.head = None

    # Tambahan: method untuk menambahkan node di akhir
    def append(self, data):
        new_node = Node(data)
        if not self.head:
            self.head = new_node
        else:
            current = self.head
            while current.next:
                current = current.next
            current.next = new_node
            new_node.prev = current

    # Tambahan: untuk menampilkan isi DLL
    def print_list(self):
        current = self.head
        while current:
            print(current.data, end=" <-> " if current.next else "")
            current = current.next
        print()

# Contoh penggunaan
if __name__ == "__main__":
    dll = DoublyLinkedList()

    dll.append(1)
    dll.append(2)
    dll.append(3)

    print("Isi DLL:")
    dll.print_list()

    print("Panjang:", dll.length())

    print("Cari 2:", dll.search(2))
    print("Cari 5:", dll.search(5))

    print("Sebelum dibalik:")
    dll.print_list()

    dll.reverse()
    print("Setelah dibalik:")
    dll.print_list()

    dll.clear()
    print("Setelah dihapus:")
    dll.print_list()
